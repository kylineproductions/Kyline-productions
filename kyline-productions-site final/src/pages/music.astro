---
import Layout from '../layouts/Layout.astro';
import SignalChain from '../components/SignalChain.astro';
---
<Layout title="Music" description="Listen on Spotify.">
  <section class="hero">
    <div class="wrap">
      <span class="kicker">Music</span>
      <h1>Listen.</h1>
      <p class="lede">Recordings, projects, and mixes — on Spotify.</p>
    </div>
  </section>

  <SignalChain labels={['Recorded', 'Mixed', 'Released']} />

  <section class="section-tight">
    <div class="wrap">
      <div class="card" style="padding:0; overflow:hidden;">
        <!-- Replace the src below with your actual Spotify artist/playlist embed URL -->
        <iframe
          style="border-radius:0; display:block;"
          src="https://open.spotify.com/embed/artist/47j7Zz7T6gDG8JsRIJaPU9?utm_source=generator&theme=0"
          width="100%"
          height="352"
          frameborder="0"
          allowfullscreen
          loading="lazy"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          title="Spotify player"
        ></iframe>
      </div>
      <p class="spec" style="margin-top:1.5rem;">
        Or follow directly on <a href="https://open.spotify.com/" target="_blank" rel="noopener">Spotify →</a>
      </p>
    </div>
  </section>
</Layout>
